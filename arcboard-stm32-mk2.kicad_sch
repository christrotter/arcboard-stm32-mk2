	)
	(text_box "Another tzarc special - figuring out how he did it helped me understand mosfets and transistors way better.\nP-channel MOSFETs are on when the gate is grounded.\nThe transistor is, by default, doing this.\nSo the normal behaviour is 'always on'.\nOptionally, if you trigger the transistor from GPIO, you can send voltage to the gate, which turns the MOSFET off."
		(exclude_from_sim no)
		(at 471.17 226.06 0)
		(size 107.95 13.97)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(face "Futura")
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "153f7359-1d12-4f26-bdac-1a82f774ac0b")
	)
